{
  "name": "viewfoundry",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "description": "Embeddable visual editor framework for React applications",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm build && pnpm test && pnpm typecheck",
    "ci": "pnpm check && pnpm lint && pnpm format:check && pnpm docs:build && pnpm test:e2e",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "pnpm --filter basic-react dev",
    "docs:build": "node scripts/build-docs.mjs",
    "docs:dev": "pnpm --filter docs-studio dev",
    "docs:preview": "python3 -m http.server 8080 --directory apps/docs/_build/html"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.1",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vite": "^6.3.4",
    "vitest": "^3.1.2"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eddiethedean/viewfoundry.git"
  }
}
