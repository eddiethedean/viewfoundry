{
  "name": "@viewfoundry/cli",
  "version": "0.4.0",
  "description": "CLI for ViewFoundry export and validation (init is a stub until v0.5.0)",
  "type": "module",
  "bin": {
    "viewfoundry": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@viewfoundry/core": "^0.4.0",
    "@viewfoundry/codegen": "^0.4.0"
  },
  "dependencies": {
    "@viewfoundry/codegen": "workspace:*",
    "@viewfoundry/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eddiethedean/viewfoundry.git",
    "directory": "packages/cli"
  }
}
